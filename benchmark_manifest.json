{
  "benchmark_id": "AIBioBench_photosynthesis_snowflake_v5",
  "version": "5.0.0",
  "repo": "github.com/karikris/AIBioBench",
  "dataset_file": "shared_dataset.json",
  "cases_file": "benchmark_cases.jsonl",
  "gold_file": "gold_answers.jsonl",
  "results_template_file": "results_template.jsonl",
  "schemas": {
    "case": "benchmark_case.schema.json",
    "gold": "gold_answer.schema.json",
    "result": "run_result.schema.json"
  },
  "standard_instructions_file": "standard_instructions.json",
  "case_count": 50,
  "default_repeats_per_case": 3,
  "default_models": [
    "mixtral-8x22b-sqlbench:latest",
    "gemma4-26b-sqlbench:latest",
    "phi4-mini-sqlbench:latest",
    "qwen2.5-72b-sqlbench:latest",
    "codellama-70b-sqlbench:latest",
    "llama3-70b-sqlbench:latest",
    "dbrx-sqlbench:latest",
    "deepseek-coder-33b-sqlbench:latest",
    "gemma4-31b-sqlbench:latest",
    "qwen2.5-coder-32b-sqlbench:latest",
    "qwen3-coder-30b-sqlbench:latest",
    "qwen3.6-sqlbench:latest",
    "qwen3.6-27b-sqlbench:latest",
    "command-r-plus-sqlbench:latest"
  ],
  "passes": {
    "1": {
      "language": "sql",
      "difficulty": "easy",
      "count": 10
    },
    "2": {
      "language": "sql",
      "difficulty": "medium",
      "count": 10
    },
    "3": {
      "language": "sql",
      "difficulty": "hard",
      "count": 10
    },
    "4": {
      "language": "python",
      "difficulty": "extra_hard",
      "count": 10
    },
    "5": {
      "language": "python",
      "difficulty": "extreme_hard",
      "count": 10
    }
  },
  "scoring_method": "row_numeric_sort_split_v1",
  "reporting_views": {
    "group_by": [
      "model_name",
      "pass",
      "difficulty",
      "language",
      "failure_family_primary",
      "failure_families",
      "procurement_score_band",
      "research_score_band",
      "model_selection_score_band"
    ],
    "summary_metrics": [
      "exact_match_rate",
      "mean_score",
      "row_set_correctness_mean",
      "numeric_correctness_mean",
      "sort_order_correctness_mean",
      "estimated_cost_usd_total",
      "cost_per_correct_answer_usd",
      "wall_s_mean"
    ],
    "repeatability_metrics": [
      "attempt_exact_match_rate",
      "attempt_score_stddev",
      "attempt_score_cv",
      "stable_failure_rate",
      "prompt_sensitive_failure_rate"
    ]
  },
  "repairable_near_miss_examples": [
    {
      "case_id": "pass2.query9",
      "example_pattern": "Correct row-set and numerics but rows sorted by pathway before condition.",
      "why_salvageable": "A human reviewer can re-sort the final table without recomputing joins.",
      "salvage_class": "human_repairable"
    },
    {
      "case_id": "pass4.query10",
      "example_pattern": "Correct join_status values but one repairable_by_human flag omitted.",
      "why_salvageable": "A reviewer can inspect the orphan pattern and recover the intended decision.",
      "salvage_class": "human_repairable"
    }
  ],
  "cost_tracking": {
    "required_result_fields": [
      "estimated_cost_usd",
      "cost_per_correct_answer_usd"
    ],
    "definition": "cost_per_correct_answer_usd = total_estimated_cost_usd / max(number_of_correct_answers, 1)"
  },
  "runner_notes": {
    "repeatability": "Run each case at least three times per model to distinguish stable failures from prompt-sensitive failures. For v5, shared standards match the shorter v2/v4 wording, case prompts match the v2/v3 base query text, and model-specific guidance is appended at runtime from query_engineering_registry/v5/model_query_guidance.json.",
    "failure_family_reporting": "Aggregate by failure_family_primary and failure_families, not only by case_id.",
    "compatibility": "Designed for the flat-root GitHub AIBioBench layout."
  },
  "default_repeat_group_id": "default_repeatability_v5",
  "query_engineering": {
    "enabled": true,
    "registry_id": "photosynthesis_snowflake_v5_model_query_guidance",
    "registry_file": "query_engineering_registry/v5/model_query_guidance.json",
    "strategy": "base_v2_v3_query_plus_model_specific_v5_addendum",
    "base_query_source": "v2/v3 benchmark_cases prompt text",
    "addendum_source": "v2 and v3 raw results plus per-pass failure-point analyses"
  }
}
