{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/karikris/AIBioBench/schemas/benchmark_case.schema.json",
  "title": "AIBioBenchBenchmarkCase",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "benchmark_id",
    "dataset_id",
    "case_id",
    "pass",
    "query",
    "difficulty",
    "language",
    "prompt",
    "standard_instructions_id",
    "expected_result_id",
    "scoring",
    "metadata"
  ],
  "properties": {
    "benchmark_id": {
      "type": "string",
      "minLength": 1
    },
    "dataset_id": {
      "type": "string",
      "minLength": 1
    },
    "case_id": {
      "type": "string",
      "pattern": "^pass[1-5]\\.query([1-9]|10)$"
    },
    "pass": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "query": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "difficulty": {
      "type": "string",
      "enum": [
        "easy",
        "medium",
        "hard",
        "extra_hard",
        "extreme_hard"
      ]
    },
    "language": {
      "type": "string",
      "enum": [
        "sql",
        "python"
      ]
    },
    "prompt": {
      "type": "string",
      "minLength": 1
    },
    "standard_instructions_id": {
      "type": "string",
      "enum": [
        "sql_v5",
        "python_v5"
      ]
    },
    "expected_result_id": {
      "type": "string",
      "pattern": "^pass[1-5]\\.query([1-9]|10)$"
    },
    "scoring": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method",
        "max_score",
        "row_order_matters",
        "column_order_matters",
        "split_weights",
        "numeric_columns",
        "sort_key_columns",
        "row_identity_columns",
        "numeric_tolerance_abs"
      ],
      "properties": {
        "method": {
          "type": "string",
          "const": "row_numeric_sort_split_v1"
        },
        "max_score": {
          "type": "number",
          "const": 1.0
        },
        "row_order_matters": {
          "type": "boolean"
        },
        "column_order_matters": {
          "type": "boolean"
        },
        "split_weights": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "row_set_correctness",
            "numeric_correctness",
            "sort_order_correctness"
          ],
          "properties": {
            "row_set_correctness": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "numeric_correctness": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "sort_order_correctness": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        },
        "numeric_columns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "sort_key_columns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "row_identity_columns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "numeric_tolerance_abs": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tags",
        "failure_family_primary",
        "failure_families",
        "audience_relevance",
        "repairability_class"
      ],
      "properties": {
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "failure_family_primary": {
          "type": "string",
          "enum": [
            "inner_join_accuracy",
            "sorting_presentation",
            "outer_join_coverage",
            "snowflake_traversal",
            "aggregation_numeric",
            "decision_support",
            "join_key_integrity",
            "orphan_key_audit",
            "ranking_and_priority",
            "failure_family_audit",
            "audit_reconciliation",
            "expression_mapping",
            "presentation_table",
            "repairability_review",
            "expression_transform",
            "statistical_summary",
            "repeatability_probe"
          ]
        },
        "failure_families": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "inner_join_accuracy",
              "sorting_presentation",
              "outer_join_coverage",
              "snowflake_traversal",
              "aggregation_numeric",
              "decision_support",
              "join_key_integrity",
              "orphan_key_audit",
              "ranking_and_priority",
              "failure_family_audit",
              "audit_reconciliation",
              "expression_mapping",
              "presentation_table",
              "repairability_review",
              "expression_transform",
              "statistical_summary",
              "repeatability_probe"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "audience_relevance": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "procurement",
            "research",
            "model_selection"
          ],
          "properties": {
            "procurement": {
              "type": "integer",
              "minimum": 1,
              "maximum": 5
            },
            "research": {
              "type": "integer",
              "minimum": 1,
              "maximum": 5
            },
            "model_selection": {
              "type": "integer",
              "minimum": 1,
              "maximum": 5
            }
          }
        },
        "repairability_class": {
          "type": "string",
          "enum": [
            "strict",
            "human_repairable"
          ]
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "pass": {
            "enum": [
              1,
              2,
              3
            ]
          }
        }
      },
      "then": {
        "properties": {
          "language": {
            "const": "sql"
          },
          "standard_instructions_id": {
            "const": "sql_v5"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "pass": {
            "enum": [
              4,
              5
            ]
          }
        }
      },
      "then": {
        "properties": {
          "language": {
            "const": "python"
          },
          "standard_instructions_id": {
            "const": "python_v5"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "pass": {
            "const": 1
          }
        }
      },
      "then": {
        "properties": {
          "difficulty": {
            "const": "easy"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "pass": {
            "const": 2
          }
        }
      },
      "then": {
        "properties": {
          "difficulty": {
            "const": "medium"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "pass": {
            "const": 3
          }
        }
      },
      "then": {
        "properties": {
          "difficulty": {
            "const": "hard"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "pass": {
            "const": 4
          }
        }
      },
      "then": {
        "properties": {
          "difficulty": {
            "const": "extra_hard"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "pass": {
            "const": 5
          }
        }
      },
      "then": {
        "properties": {
          "difficulty": {
            "const": "extreme_hard"
          }
        }
      }
    }
  ]
}
